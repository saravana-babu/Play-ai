{
  "manifest_version": 3,
  "name": "Play AI Web Assistant",
  "version": "1.0.0",
  "description": "Premium AI-powered web assistant by play-ai.in",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.deepseek.com/*",
    "https://api.groq.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "commands": {
    "open-assistant": {
      "suggested_key": {
        "default": "Alt+Shift+Space",
        "mac": "Alt+Shift+Space"
      },
      "description": "Open Play AI Assistant"
    }
  },
  "icons": {
    "128": "icons/icon.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}
